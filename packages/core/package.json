{
  "name": "@statusmap/core",
  "version": "0.1.0",
  "description": "Honest, test-aware project status maps: the typed definition contract, the status policy (health math + proof-level ladder), the rollup engine, and vitest/playwright test-artifact ingestion. Framework-agnostic, zero runtime dependencies.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./src/styles/statusmap.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint:pkg": "publint && attw --pack . --exclude-entrypoints styles.css",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build && npm test && npm run typecheck"
  },
  "keywords": [
    "status",
    "dashboard",
    "feature-health",
    "roadmap",
    "test-coverage",
    "vitest",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danail-Irinkov/statusmap.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Danail-Irinkov/statusmap#readme",
  "bugs": {
    "url": "https://github.com/Danail-Irinkov/statusmap/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@arethetypeswrong/cli": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.0",
    "js-yaml": "^4.1.0",
    "publint": "latest",
    "tsdown": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
